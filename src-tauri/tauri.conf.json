{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/src/tauri/conf.schema.json",
  "productName": "md-browser",
  "version": "0.1.0",
  "identifier": "com.md-browser.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "md-browser",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "mimeType": "text/markdown",
        "role": "Editor"
      }
    ]
  }
}
